# Provider selection - lets us swap OpenAI/Anthropic without touching agent logic
LLM_PROVIDER=openai              # openai | anthropic | fake (fake = deterministic, no network, used in tests)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_AGENT_ITERATIONS=6
MAX_VERIFICATION_RETRIES=2
